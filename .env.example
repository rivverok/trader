# ============================================================
# AI Trading Platform — Environment Configuration
# ============================================================
# Copy this file to .env and fill in all values.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=ai-trader
APP_ENV=development                # development | production
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=                        # Random string for session signing. Generate with: openssl rand -hex 32
TRADING_MODE=paper                 # paper | live — DO NOT set to "live" until Stage 7

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=trader
POSTGRES_USER=trader
POSTGRES_PASSWORD=                 # Choose a strong password
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ── Alpaca (Broker + Market Data) ────────────────────────────
# Sign up: https://alpaca.markets
# Paper trading keys: https://app.alpaca.markets/paper/dashboard/overview → API Keys
# Live trading keys:  https://app.alpaca.markets/live/dashboard/overview → API Keys
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets    # Paper trading URL
# For live trading (Stage 7+), change to:
# ALPACA_BASE_URL=https://api.alpaca.markets

# ── Anthropic (Claude API) ───────────────────────────────────
# Sign up: https://console.anthropic.com
# Create key: Console → API Keys → Create Key
# Add billing: Console → Plans & Billing
ANTHROPIC_API_KEY=
CLAUDE_MODEL_FAST=claude-3-5-haiku-20241022        # For simple sentiment scoring
CLAUDE_MODEL_SMART=claude-sonnet-4-20250514     # For complex analysis & decision synthesis

# ── Finnhub (News + Company Data) ────────────────────────────
# Sign up: https://finnhub.io
# API token: Dashboard → API Token (auto-generated on signup)
FINNHUB_API_KEY=

# ── FRED (Federal Reserve Economic Data) ─────────────────────
# Sign up: https://fred.stlouisfed.org/docs/api/api_key.html
# Request key: instant approval after account creation
FRED_API_KEY=

# ── SEC EDGAR ────────────────────────────────────────────────
# No API key needed. SEC requires a User-Agent header with your
# name and email so they can contact you if there's an issue.
# Format: "YourName your.email@example.com"
SEC_EDGAR_USER_AGENT=

# ── Risk Management Defaults ─────────────────────────────────
# These can also be adjusted via the web UI at runtime.
RISK_MAX_TRADE_DOLLARS=1000        # Max $ per single trade
RISK_MAX_POSITION_PCT=10           # Max % of portfolio in one stock
RISK_MAX_SECTOR_PCT=25             # Max % of portfolio in one sector
RISK_DAILY_LOSS_LIMIT=500          # Halt trading if daily realized loss exceeds this $
RISK_MAX_DRAWDOWN_PCT=15           # Halt trading if portfolio drops this % from peak
RISK_MIN_CONFIDENCE=0.6            # Don't trade if confidence below this (0.0-1.0)

# ── Signal Weights (must sum to 1.0) ─────────────────────────
# These can also be adjusted via the web UI at runtime.
SIGNAL_WEIGHT_ML=0.3               # XGBoost/LightGBM technical signal
SIGNAL_WEIGHT_CLAUDE=0.4           # Claude sentiment + analysis
SIGNAL_WEIGHT_ANALYST=0.3          # Your personal analyst input

# ── Trading Parameters ───────────────────────────────────────
POSITION_SIZE_METHOD=fixed_fractional   # fixed_fractional | kelly
POSITION_SIZE_RISK_PCT=2           # Risk this % of portfolio per trade
DEFAULT_STOP_LOSS_PCT=5            # Default stop-loss at -X%
DEFAULT_TAKE_PROFIT_PCT=10         # Default take-profit at +X%
AUTO_EXECUTE=false                 # false = require manual approval; true = auto-execute

# ── Autonomous Mode ──────────────────────────────────────────
# Seed the account (e.g. $1000) and let the system manage it hands-off.
# It will invest, sell, and reinvest with the goal of growing account value.
# Enables auto-execute and uses portfolio-proportional position sizing.
AUTONOMOUS_MODE=false
AUTONOMOUS_POSITION_PCT=10         # Each trade = up to X% of portfolio, scaled by confidence

# ── Scheduled Task Intervals ─────────────────────────────────
COLLECT_PRICES_INTERVAL_SEC=60     # Collect prices during market hours
COLLECT_NEWS_INTERVAL_SEC=1800     # Collect news (30 min)
COLLECT_ECONOMIC_INTERVAL_SEC=86400 # Collect economic data (24 hours)
COLLECT_FILINGS_INTERVAL_SEC=21600 # Collect SEC filings (6 hours)
ANALYZE_NEWS_INTERVAL_SEC=900      # Run Claude news analysis (15 min)
ANALYZE_FILINGS_INTERVAL_SEC=3600  # Run Claude filing analysis (1 hour)
CONTEXT_SYNTHESIS_INTERVAL_SEC=7200 # Run Claude context synthesis (2 hours)
DECISION_CYCLE_INTERVAL_SEC=1800   # Run decision engine (30 min)
ML_SIGNAL_INTERVAL_SEC=3600        # Generate ML signals (1 hour)
PORTFOLIO_SYNC_INTERVAL_SEC=300    # Sync portfolio with Alpaca (5 min)

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=/api           # Backend API URL (proxied through Caddy)

# ── Caddy / HTTPS ────────────────────────────────────────────
# Caddy handles HTTPS automatically. Set the domain/address here.
# For home network (IP access): use :443 or localhost
# For a real domain: use trader.yourdomain.com (auto Let's Encrypt)
CADDY_SITE_ADDRESS=:443

# ── Email Alerts (Optional — Stage 7) ────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=                   # Use App Password if using Gmail
# ALERT_EMAIL_TO=

# ── Training PC Database Access (for training scripts) ───────
# Only needed on the GTX 5070 TI training PC, not on the trading server.
# Set this to the trading server's LAN IP so training scripts can
# read historical data directly from PostgreSQL.
# TRAINING_DATABASE_URL=postgresql://trader:password@192.168.1.XXX:5432/trader

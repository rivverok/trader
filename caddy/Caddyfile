{$CADDY_SITE_ADDRESS:localhost} {
	# API → FastAPI backend
	handle /api/* {
		reverse_proxy api:8000
	}

	# WebSocket support for live updates
	handle /ws/* {
		reverse_proxy api:8000
	}

	# Everything else → Next.js frontend
	handle {
		reverse_proxy frontend:3000
	}

	log {
		output stdout
		format console
	}
}
